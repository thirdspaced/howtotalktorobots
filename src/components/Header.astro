---
const nav = [
  { href: '/library/', label: 'Library' },
  { href: '/guides/teachers/', label: 'For Teachers' },
  { href: '/guides/parents/', label: 'For Parents' },
  { href: '/guides/business/', label: 'For Business' },
  { href: '/about/', label: 'About' },
];
const path = Astro.url.pathname;
---

<header class="site-header">
  <div class="wrap">
    <a class="wordmark" href="/">how to talk to robots</a>
    <nav class="site-nav" aria-label="Main">
      <ul>
        {nav.map(({ href, label }) => (
          <li>
            <a href={href} aria-current={path.startsWith(href) ? 'page' : undefined}>{label}</a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>
