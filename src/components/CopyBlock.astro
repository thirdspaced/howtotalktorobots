---
interface Props {
  text: string;
  label?: string;
}
const { text, label = 'Copy this prompt' } = Astro.props;
---

<div class="copy-block">
  <pre>{text}</pre>
  <button type="button" data-copy>{label}</button>
  <span class="sr-status" aria-live="polite" style="position:absolute; left:-9999px;"></span>
</div>

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-copy]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const block = btn.closest('.copy-block');
      const text = block?.querySelector('pre')?.textContent ?? '';
      const status = block?.querySelector('.sr-status');
      try {
        await navigator.clipboard.writeText(text);
        const original = btn.textContent;
        btn.textContent = 'Copied — paste it into ChatGPT or Claude';
        btn.classList.add('copied');
        if (status) status.textContent = 'Prompt copied to clipboard';
        setTimeout(() => {
          btn.textContent = original;
          btn.classList.remove('copied');
        }, 2600);
      } catch {
        if (status) status.textContent = 'Copy failed — select the text and copy it manually';
        btn.textContent = 'Select the text above and copy it';
      }
    });
  });
</script>
