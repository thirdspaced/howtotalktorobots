---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import TagPill from '../../components/TagPill.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, date, updated, author, tags, canonical } = post.data;

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  author: { '@type': 'Person', name: author },
  datePublished: date.toISOString(),
  ...(updated ? { dateModified: updated.toISOString() } : {}),
  publisher: {
    '@type': 'EducationalOrganization',
    name: 'how to talk to robots',
    url: 'https://www.talktorobots.org',
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.talktorobots.org/' },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://www.talktorobots.org/blog/' },
    { '@type': 'ListItem', position: 3, name: title },
  ],
};
---

<Base
  title={`${title} — how to talk to robots`}
  description={description}
  schema={[articleSchema, breadcrumbSchema]}
  canonicalUrl={canonical}
>
  <article class="prose section">
    <nav aria-label="Breadcrumb" style="font-size: var(--text-sm); margin-bottom: 1rem;">
      <a href="/blog/">← Back to the blog</a>
    </nav>

    <h1>{title}</h1>

    <p style="font-size: var(--text-sm); color: var(--ink-soft); margin-bottom: 0.25rem;">
      By {author} · {fmt(date)}
      {updated && <span> · Updated {fmt(updated)}</span>}
    </p>

    {tags.length > 0 && (
      <div class="entry-meta">
        {tags.map((t) => (
          <a href={`/blog/tags/${t}/`} style="text-decoration: none;">
            <TagPill label={t} kind="topic" />
          </a>
        ))}
      </div>
    )}

    <Content />

    <hr style="border: none; border-top: 1px solid var(--card-line); margin: 2.5rem 0 1.5rem;" />
    <p style="font-size: var(--text-sm); color: var(--ink-soft);">
      Want to learn more? Browse the <a href="/library/">resource library</a> or
      <a href="/contribute/">contribute your own guide</a>.
    </p>
  </article>
</Base>
