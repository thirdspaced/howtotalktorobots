---
import Base from '../layouts/Base.astro';
import SearchBar from '../components/SearchBar.astro';
---

<Base
  title="Page not found — how to talk to robots"
  description="That page doesn't exist — but the answer probably does. Search the library."
  index={false}
>
  <div class="hero wrap">
    <h1>Hmm, that page isn't here.</h1>
    <p class="tagline">The answer probably is, though. Try searching:</p>
    <SearchBar />
    <p style="margin-top: 1.5rem;">
      Or <a href="/library/">browse the whole library</a> ·
      <a href="/">go home</a>
    </p>
  </div>
</Base>
